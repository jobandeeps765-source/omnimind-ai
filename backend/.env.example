# ---- Core ----
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=omnimind
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---- LLM providers (all optional) ----
# Leave all of these blank to run in fully offline / deterministic demo mode.
# If more than one is set, OMNIMIND_FORCE_PROVIDER decides which wins;
# otherwise the app auto-selects the first available in this priority order:
# anthropic > openai > gemini > ollama > offline
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Force a specific provider regardless of what's configured.
# One of: openai | anthropic | gemini | ollama | offline | (blank = auto)
OMNIMIND_FORCE_PROVIDER=

# ---- Redis (background jobs) ----
REDIS_URL=redis://localhost:6379/0

# ---- CORS ----
FRONTEND_ORIGIN=http://localhost:3000
